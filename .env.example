# ============================================
# SIAP PKL - Environment Variables Example
# ============================================
# Copy file ini ke `.env` lalu isi value sesuai environment lokal/production.
# JANGAN commit file `.env` ke git (sudah ada di .gitignore).

# ----- Database (Postgres via Docker Compose) -----
# Credentials ini harus match dengan yang di docker-compose.yml.
# Kalau Anda pakai Postgres lain, ganti host/port/user/password/db.
DATABASE_URL="postgresql://siap_pkl:siap_pkl_dev@localhost:5432/siap_pkl?schema=public"

# ----- Auth.js v5 -----
# Secret untuk sign JWT/session. Generate dengan:
#   openssl rand -base64 32
# Di Windows bisa pakai:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="ganti-dengan-string-acak-panjang-minimum-32-karakter"

# URL aplikasi (dipakai Auth.js untuk callback). Untuk dev biarkan default.
# Di production, ganti ke domain produksi (https://siap-pkl.sekolah.sch.id).
AUTH_URL="http://localhost:3000"

# Set ke "true" kalau mau verbose log Auth.js (debug auth issue)
AUTH_DEBUG="false"

# Trust host header. Di dev "true" agar Auth.js tidak memaksa AUTH_URL exact.
AUTH_TRUST_HOST="true"

# ----- Sekolah (fallback kalau SystemConfig kosong) -----
# Koordinat SMKN 1 Badegan (kira-kira). Dipakai engine SAW untuk hitung jarak.
NEXT_PUBLIC_SEKOLAH_LATITUDE="-7.9124"
NEXT_PUBLIC_SEKOLAH_LONGITUDE="111.3956"
NEXT_PUBLIC_SEKOLAH_NAMA="SMKN 1 Badegan"

# ----- Admin seed (dipakai prisma/seed.ts di milestone 7) -----
SEED_ADMIN_EMAIL="admin@siap-pkl.local"
SEED_ADMIN_PASSWORD="admin123"
