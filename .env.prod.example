# Contoh variabel environment produksi untuk `docker-compose.prod.yml`.
# Salin ke `.env.prod` dan isi dengan nilai sesungguhnya.
#
# ⚠️ JANGAN commit `.env.prod` ke git.

# --- Database (internal ke compose network) ---
POSTGRES_USER=siap_pkl
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_MINIMAL_24_KARAKTER
POSTGRES_DB=siap_pkl

# --- Auth.js v5 ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=GANTI_DENGAN_HASIL_GENERATE_32_BYTES
# AUTH_URL harus match domain publik (WAJIB di production — Auth.js v5
# butuh ini untuk cookie `__Secure-authjs.session-token` + callback URL).
AUTH_URL=https://siap-pkl.example.com

# --- Seed admin awal ---
[email protected]
SEED_ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN_AWAL

# --- Koordinat sekolah (untuk SAW jarak) ---
NEXT_PUBLIC_SEKOLAH_LATITUDE=-7.9124
NEXT_PUBLIC_SEKOLAH_LONGITUDE=111.3956

# --- Port host untuk app container (varian aaPanel) ---
# Ganti kalau port 3100 sudah dipakai service lain di VPS.
# Cek dengan: ss -tlnp | grep 3100
APP_PORT=3100
